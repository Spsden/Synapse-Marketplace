# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres

# Storage Configuration
SIGNED_URL_TTL_SECONDS=3600
MAX_UPLOAD_SIZE_MB=50

# Storage Buckets
STORAGE_PLUGINS_BUCKET=plugins
STORAGE_ICONS_BUCKET=icons
STORAGE_TEMP_UPLOADS_BUCKET=temp_uploads

# Timeout Configuration
TIMEOUT_SUBMISSION_SECONDS=5
TIMEOUT_SUBMISSION_ENABLED=true

# Vault Configuration (for OAuth token encryption)
# Generate with: openssl rand -base64 32
VAULT_ENCRYPTION_KEY=your-32-byte-base64-encoded-key-here

# OAuth Configuration
# Server URL for OAuth callbacks (required for HTTPS-only providers like Notion and Slack)
SERVER_URL=https://your-marketplace.com
OAUTH_CALLBACK_BASE_URL=http://localhost:3000
